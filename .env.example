# =============================================================================
# Douyin Video Translator - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.

# --- Redis ---
# Main Redis connection for job state storage
REDIS_URL=redis://localhost:6379/0

# --- Storage ---
# Path for storing job artifacts (downloaded videos, audio files, output)
STORAGE_PATH=storage/jobs

# --- Concurrency ---
# Maximum number of concurrent translation jobs per user
MAX_CONCURRENT_JOBS=5

# --- File Expiry ---
# Hours before completed job files are cleaned up
FILE_EXPIRY_HOURS=24

# --- Retry Settings ---
# Maximum retry attempts for network failures
MAX_RETRY_ATTEMPTS=3
# Base for exponential backoff calculation (delay = base ^ attempt seconds)
RETRY_BACKOFF_BASE=2

# --- Audio Mixing ---
# Background music volume level (0.0 = silent, 1.0 = full volume)
BACKGROUND_VOLUME=0.2

# --- Celery ---
# Redis connection for Celery task broker
CELERY_BROKER_URL=redis://localhost:6379/1
# Redis connection for Celery result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/1
